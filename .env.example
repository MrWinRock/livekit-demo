LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Direct provider API keys (optional). If set, the agent uses these provider
# plugins directly and bypasses LiveKit Inference for that component. If unset,
# the corresponding component falls back to LiveKit Inference (which uses your
# LiveKit Cloud gateway credits). Each key works independently — you can mix.
#
# LLM precedence (first match wins): GOOGLE_API_KEY → OPENAI_API_KEY → Inference
#   GOOGLE_API_KEY     → LLM via livekit-plugins-google (gemini-3.1-flash-lite-preview)
#   OPENAI_API_KEY     → LLM via livekit-plugins-openai (gpt-4o-mini)
#   DEEPGRAM_API_KEY   → STT via livekit-plugins-deepgram (nova-2, th)
#   CARTESIA_API_KEY   → TTS via livekit-plugins-cartesia (sonic-3)
GOOGLE_API_KEY=
OPENAI_API_KEY=
DEEPGRAM_API_KEY=
CARTESIA_API_KEY=

# Beyond Presence
BEY_API_KEY=
BEY_AVATAR_ID=

TAVUS_API_KEY=
TAVUS_REPLICA_ID=
TAVUS_PERSONA_ID=

# Web search
# Choose "ddg" (default, no key needed) or "tavily".
WEB_SEARCH_PROVIDER=ddg
# Required only when WEB_SEARCH_PROVIDER=tavily. Get a key at https://tavily.com/.
TAVILY_API_KEY=

# RAG-UI backend integration (optional — leave unset to use the default
# relative path that assumes the backend lives at ../../ai/backend).
# Set explicitly if your backend lives elsewhere.
BACKEND_DB_PATH=
BACKEND_STORAGE_PATH=

# Real-time prompter UI (default: 7860). Open http://localhost:PROMPTER_PORT
# while the agent is running to feed text directly to the agent's TTS.
PROMPTER_PORT=7860